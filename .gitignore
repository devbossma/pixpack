# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Next.js build output ────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ─── Environment variables ────────────────────────────────────────────────────
# NEVER commit any .env file except .env.example
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ─── Google Cloud credentials ─────────────────────────────────────────────────
# Service account JSON files — contain private keys
# These MUST never be committed under any name or extension
service-account.json
service-account*.json
*-service-account.json
*.key.json
gcloud-credentials.json
google-credentials.json
credentials.json

# Block any JSON file that might be a service account
# (too broad? Better safe than a private key leak)
# Uncomment if you store other JSONs in the root:
# *.json

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── OS and editor files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

